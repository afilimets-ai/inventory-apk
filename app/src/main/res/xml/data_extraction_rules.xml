<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude scanner settings and sensitive data from cloud backup -->
        <exclude domain="sharedpref" path="scanner_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="."/>
    </device-transfer>
</data-extraction-rules>
